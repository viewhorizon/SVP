VITE_API_BASE_URL=http://localhost:8787

# Backend (referencia para backend/src/app.ts)
PORT=8787
DATABASE_URL=postgres://postgres:postgres@localhost:5432/svp
FRONTEND_ORIGIN=http://localhost:5173

# Auth backend
AUTH_MODE=dev
AUTH_INSECURE_FALLBACK=false
FIREBASE_PROJECT_ID=
FIREBASE_SERVICE_ACCOUNT_JSON=

# Votes API rate limiting
VOTES_RATE_LIMIT_WINDOW_MS=60000
VOTES_RATE_LIMIT_MAX=30

# Planning AI provider
# local: analisis deterministico sin proveedor externo
# openai_compatible: usa /chat/completions de un proveedor compatible
PLANNING_AI_MODE=local
PLANNING_AI_BASE_URL=
PLANNING_AI_API_KEY=
PLANNING_AI_MODEL=

# Webhooks (opcional)
WEBHOOK_SHARED_SECRET=
WEBHOOK_SIGNING_SECRET=
WEBHOOK_HMAC_TOLERANCE_SECONDS=300
LEDGER_AUDIT_SIGNING_SECRET=

# Outbox dispatcher worker (0 = deshabilitado)
OUTBOX_DISPATCH_INTERVAL_MS=0
OUTBOX_DISPATCH_BATCH_LIMIT=25
OUTBOX_DISPATCH_URL=